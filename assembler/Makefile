CXX = g++-15
LEX = flex
YACC = /opt/homebrew/opt/bison/bin/bison

SRC_DIR = src
INCLUDE_DIR = include
BUILD_DIR = build
TESTS_DIR = tests
BIN_DIR = bin

FRONTEND_DIR = $(SRC_DIR)/frontend

CXXFLAGS = -std=c++17 -Wall -Wextra -I./$(INCLUDE_DIR) -I./$(BUILD_DIR) -MMD -MP
LDFLAGS = 

# Source files
LEX_SRC = $(FRONTEND_DIR)/lexer.flex
YACC_SRC = $(FRONTEND_DIR)/parser.y
CPP_SRCS = $(shell find $(SRC_DIR) -name '*.cpp')

# Generated files
LEX_OUT = $(BUILD_DIR)/lex.yy.c
YACC_OUT = $(BUILD_DIR)/parser.tab.cpp
YACC_HDR = $(BUILD_DIR)/parser.tab.hpp

# Object files
OBJS = $(BUILD_DIR)/lex.yy.o $(BUILD_DIR)/parser.tab.o \
       $(patsubst $(SRC_DIR)/%.cpp, $(BUILD_DIR)/%.o, $(CPP_SRCS))

# Dependency files generated by the compiler
DEPS = $(OBJS:.o=.d)

# Target executable
TARGET = $(BIN_DIR)/vas

# Default rule
all: $(TARGET)

# Link the final compiler binary
$(TARGET): $(OBJS)
	@mkdir -p $(BIN_DIR)
	$(CXX) $(CXXFLAGS) $(OBJS) -o $(TARGET) $(LDFLAGS)

# Compile C++ sources
$(BUILD_DIR)/%.o: $(SRC_DIR)/%.cpp
	@mkdir -p $(BUILD_DIR)
	@mkdir -p $(BUILD_DIR)/frontend
	@mkdir -p $(BUILD_DIR)/backend
	$(CXX) $(CXXFLAGS) -c $< -o $@

# Compile Flex output 
$(BUILD_DIR)/lex.yy.o: $(LEX_OUT) $(YACC_HDR)
	@mkdir -p $(BUILD_DIR)
	$(CXX) $(CXXFLAGS) -c $< -o $@

# Compile Bison output
$(BUILD_DIR)/parser.tab.o: $(YACC_OUT)
	@mkdir -p $(BUILD_DIR)
	$(CXX) $(CXXFLAGS) -c $< -o $@

# Run Bison (generates parser.tab.cpp and parser.tab.hpp)
$(YACC_OUT) $(YACC_HDR): $(YACC_SRC)
	@mkdir -p $(BUILD_DIR)
	$(YACC) -d -o $(YACC_OUT) $<

# Run Flex (depends on Bison header for tokens)
$(LEX_OUT): $(LEX_SRC) $(YACC_HDR)
	@mkdir -p $(BUILD_DIR)
	$(LEX) -o $@ $<

# Clean up
clean:
	rm -rf $(BUILD_DIR)

# Include the auto-generated dependency files
-include $(DEPS)

.PHONY: all clean